class EstadoRabisco(EstadoDesenho):
    """
    @brief Estado da ferramenta Rabisco (traço livre).

    Difere das figuras de arraste porque, ao invés de mover apenas um
    ponto final, acumula cada posição visitada pelo mouse durante o
    arraste (`adicionar_ponto`).

    @author Felipe Machado e Ranieri Pereira
    @version 3.0
    @since 2026-07-19
    """

    def iniciar(self, controlador, event):
        cb = controlador.visao.cor_borda
        controlador.figuranova = Rabisco(event.x, event.y, cb)

    def atualizar(self, controlador, event):
        if controlador.figuranova is None:
            return
        controlador.figuranova.adicionar_ponto(event.x, event.y)
        controlador.visao.desenhar_figuras(controlador.desenho.figuras)
        controlador.visao.desenhar_figuranova(controlador.figuranova)

    def incluir(self, controlador, event):
        if controlador.figuranova is not None and not controlador.figuranova.incompleta():
            controlador.desenho.figuras.append(controlador.figuranova)
            controlador.figuranova = None
        controlador.visao.desenhar_figuras(controlador.desenho.figuras)


class EstadoPoligono(EstadoDesenho):
    """
    @brief Estado da ferramenta Polígono.

    Cada clique do botão esquerdo adiciona um vértice novo (ao invés de
    iniciar uma figura nova a cada clique, como as demais ferramentas).
    A figura só é efetivamente incluída no desenho ao clicar com o botão
    direito, comportamento herdado de EstadoDesenho.finalizar_poligono —
    por isso `incluir` (soltar o botão esquerdo) não faz nada aqui.

    @author Felipe Machado e Ranieri Pereira
    @version 3.0
    @since 2026-07-19
    """

    def iniciar(self, controlador, event):
        if controlador.figuranova is not None:
            controlador.figuranova.adicionar_ponto(event.x, event.y)
            controlador.visao.desenhar_figuras(controlador.desenho.figuras)
            controlador.visao.desenhar_figuranova(controlador.figuranova)
        else:
            cb = controlador.visao.cor_borda
            cp = controlador.visao.cor_preenchimento
            controlador.figuranova = Poligono(event.x, event.y, cb, cp)

    def atualizar(self, controlador, event):
        if controlador.figuranova is None:
            return
        controlador.visao.desenhar_figuras(controlador.desenho.figuras)
        controlador.visao.desenhar_figuranova(controlador.figuranova)
        ultimo = controlador.figuranova.pontos[-1]
        controlador.visao.areadesenho.create_line(
            ultimo[0], ultimo[1], event.x, event.y,
            fill=controlador.figuranova.cor_borda, dash=(4, 2)
        )

    def incluir(self, controlador, event):
        """
        @brief Não finaliza o polígono ao soltar o botão esquerdo.

        A finalização do polígono acontece apenas em
        `finalizar_poligono`, disparado pelo clique com o botão direito.
        """
        pass
